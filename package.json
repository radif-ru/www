{
  "name": "radif-ru-www",
  "version": "1.0.0",
  "private": true,
  "description": "Персональный сайт-резюме radif.ru — статический сайт (HTML/CSS/JS) за Nginx в Docker.",
  "homepage": "https://radif.ru/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radif-ru/www.git"
  },
  "license": "MIT",
  "author": "Радиф Илалтдинов <i@radif.ru> (https://radif.ru/)",
  "scripts": {
    "lint": "npm run lint:css && npm run lint:js && npm run lint:html",
    "lint:css": "stylelint \"assets/**/*.css\"",
    "lint:js": "eslint assets",
    "lint:html": "html-validate index.html",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "html-validate": "^9.1.3",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.2",
    "stylelint-config-standard": "^36.0.1"
  }
}
